{
  "name": "education-insight-skill",
  "version": "1.0.0",
  "description": "Skill for analyzing educational indicators from the World Bank Education Statistics (EdStats) dataset.",
  "author": "Bárbara Castro",
  "language": "en",
  "domain": "Education Analytics",
  "input": {
    "type": "object",
    "properties": {
      "countries": {
        "type": "array",
        "description": "ISO-3 country codes.",
        "items": {
          "type": "string"
        }
      },
      "indicators": {
        "type": "array",
        "description": "World Bank education indicator codes.",
        "items": {
          "type": "string"
        }
      },
      "start_year": {
        "type": "integer",
        "description": "Initial year of the analysis."
      },
      "end_year": {
        "type": "integer",
        "description": "Final year of the analysis."
      }
    },
    "required": [
      "countries",
      "indicators"
    ]
  },
  "output": {
    "type": "object",
    "properties": {
      "executive_summary": {
        "type": "string"
      },
      "metrics": {
        "type": "array"
      },
      "rankings": {
        "type": "array"
      },
      "comparisons": {
        "type": "array"
      },
      "insights": {
        "type": "array"
      }
    }
  },
  "capabilities": [
    "Country comparison",
    "Indicator interpretation",
    "Historical trend analysis",
    "Educational performance evaluation",
    "Executive reporting",
    "Evidence-based insights"
  ],
  "limitations": [
    "Does not predict future values.",
    "Does not infer causality.",
    "Depends on processed EdStats data."
  ]
}